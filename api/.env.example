# Copy to .env on the server and fill in
# If MariaDB/MySQL runs on the same machine (the Docker host), use:
# DB_HOST=host.docker.internal
DB_HOST=host.docker.internal

# Host port to publish the API on (container listens on 8000 internally)
API_PORT=8001

DB_USER=proteomes_api
DB_PASSWORD=secure_password
DB_NAME=bbc_proteomes
DATA_SOURCE=proteomes_flat_mat
# VIEW_NAME=view_proteomes_flat_v2
